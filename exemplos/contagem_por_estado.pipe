# Pipeline: quantidade de transacoes de eletronicos por estado

pipeline "Transacoes Eletronicos por Estado"
  load "dados_vendas.csv"
  filter coluna="categoria" valor="Eletronicos"
  group_by coluna="estado" agregacao=contagem
  plot tipo=bar eixo_x="estado" eixo_y="vendas"
  export "resultado_estados_eletronicos.csv"
end
